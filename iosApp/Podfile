source 'https://cdn.cocoapods.org'

platform :ios, '14.0'
use_frameworks!

def ooni_podspec(name, version)
    "https://repo1.maven.org/maven2/org/ooni/#{name}-ios/#{version}/#{name}-ios-#{version}.podspec"
end

def shared_pods
    ooni_version = "0.0.0-51fd60f6"
    passport_version = "0.1.4-beta"

    pod 'composeApp', :path => '../composeApp'

    pod 'sqlite3', '~> 3.42.0'

    pod "libcrypto", :podspec => ooni_podspec("libcrypto", ooni_version)
    pod "libevent", :podspec => ooni_podspec("libevent", ooni_version)
    pod "libssl", :podspec => ooni_podspec("libssl", ooni_version)
    pod "libtor", :podspec => ooni_podspec("libtor", ooni_version)
    pod "libz", :podspec => ooni_podspec("libz", ooni_version)
    pod "oonimkall", :podspec => ooni_podspec("oonimkall", ooni_version)
    pod "passport", :podspec => ooni_podspec("passport", passport_version)
    pod "Siren"
end

target 'OONIProbe' do
    shared_pods
end

target 'OONIProbeUITests' do
    shared_pods
end

target 'NewsMediaScan' do
    shared_pods
end

target 'NewsMediaScanUITests' do
    shared_pods
end
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
